<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - CS Bot</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body text-center">
                        <i class="fas fa-exclamation-triangle fa-4x text-warning mb-4"></i>
                        <h3 class="card-title">Oops! Something went wrong</h3>
                        <p class="card-text text-muted">
                            <%= message || 'An unexpected error occurred' %>
                        </p>
                        <% if (locals.error && process.env.NODE_ENV === 'development') { %>
                            <div class="alert alert-danger text-start mt-4">
                                <h6>Error Details:</h6>
                                <pre class="mb-0"><%= error.stack %></pre>
                            </div>
                        <% } %>
                        <div class="mt-4">
                            <a href="/dashboard" class="btn btn-primary me-2">
                                <i class="fas fa-home me-2"></i>Go to Dashboard
                            </a>
                            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Go Back
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>