<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'CS Bot' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <% if (locals.user) { %>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/dashboard">
                <i class="fab fa-whatsapp me-2"></i>CS Bot
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard/chat">
                            <i class="fas fa-comments me-1"></i>Chat
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/bulk">
                            <i class="fas fa-bullhorn me-1"></i>Bulk Message
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard/settings">
                            <i class="fas fa-cog me-1"></i>Settings
                        </a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <span class="navbar-text me-3">
                            <span id="whatsapp-status" class="badge bg-danger">Disconnected</span>
                        </span>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user me-1"></i><%= user.username %>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/logout">
                                <i class="fas fa-sign-out-alt me-1"></i>Logout
                            </a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <% } %>

    <!-- Flash Messages -->
    <% if (locals.success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (locals.error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (locals.error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Main Content -->
    <main class="<%= locals.user ? 'container-fluid mt-4' : '' %>">
        
<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-bullhorn me-2"></i>Bulk Messaging</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newCampaignModal">
                <i class="fas fa-plus me-2"></i>New Campaign
            </button>
        </div>
    </div>
</div>

<!-- Campaign Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title"><%= campaigns ? campaigns.length : 0 %></h4>
                        <p class="card-text">Total Campaigns</p>
                    </div>
                    <div class="align-self-center">
                        <i class="fas fa-bullhorn fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">
                            <%= campaigns ? campaigns.filter(c => c.status === 'completed').length : 0 %>
                        </h4>
                        <p class="card-text">Completed</p>
                    </div>
                    <div class="align-self-center">
                        <i class="fas fa-check-circle fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">
                            <%= campaigns ? campaigns.filter(c => c.status === 'running').length : 0 %>
                        </h4>
                        <p class="card-text">Running</p>
                    </div>
                    <div class="align-self-center">
                        <i class="fas fa-clock fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-secondary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">
                            <%= campaigns ? campaigns.filter(c => c.status === 'pending').length : 0 %>
                        </h4>
                        <p class="card-text">Pending</p>
                    </div>
                    <div class="align-self-center">
                        <i class="fas fa-pause-circle fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Campaign List -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-list me-2"></i>Recent Campaigns
                </h5>
            </div>
            <div class="card-body">
                <% if (campaigns && campaigns.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Campaign Name</th>
                                    <th>Status</th>
                                    <th>Total Contacts</th>
                                    <th>Sent</th>
                                    <th>Failed</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% campaigns.forEach(campaign => { %>
                                <tr>
                                    <td>
                                        <div class="fw-bold"><%= campaign.name %></div>
                                        <div class="text-muted small">
                                            <%= campaign.message_template.length > 50 ? campaign.message_template.substring(0, 50) + '...' : campaign.message_template %>
                                        </div>
                                    </td>
                                    <td>
                                        <% 
                                        let badgeClass = 'secondary';
                                        if (campaign.status === 'completed') badgeClass = 'success';
                                        else if (campaign.status === 'running') badgeClass = 'warning';
                                        else if (campaign.status === 'failed') badgeClass = 'danger';
                                        %>
                                        <span class="badge bg-<%= badgeClass %>">
                                            <%= campaign.status.charAt(0).toUpperCase() + campaign.status.slice(1) %>
                                        </span>
                                    </td>
                                    <td><%= campaign.total_contacts %></td>
                                    <td><%= campaign.sent_count %></td>
                                    <td><%= campaign.failed_count %></td>
                                    <td><%= new Date(campaign.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/bulk/campaign/<%= campaign.id %>" class="btn btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <% if (campaign.status === 'pending') { %>
                                                <button class="btn btn-outline-success start-campaign-btn" 
                                                        data-campaign-id="<%= campaign.id %>">
                                                    <i class="fas fa-play"></i>
                                                </button>
                                            <% } %>
                                            <button class="btn btn-outline-danger delete-campaign-btn" 
                                                    data-campaign-id="<%= campaign.id %>">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="fas fa-bullhorn fa-3x text-muted mb-3"></i>
                        <p class="text-muted">No campaigns created yet</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newCampaignModal">
                            <i class="fas fa-plus me-2"></i>Create Your First Campaign
                        </button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- New Campaign Modal -->
<div class="modal fade" id="newCampaignModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-plus me-2"></i>Create New Campaign
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form action="/bulk/upload" method="POST" enctype="multipart/form-data" id="campaign-form">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="campaignName" class="form-label">Campaign Name</label>
                                <input type="text" class="form-control" id="campaignName" name="campaignName" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="excelFile" class="form-label">Excel File</label>
                                <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" required>
                                <div class="form-text">Upload Excel file with 'phone' column (and optional 'name' column)</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="message" class="form-label">Message Template</label>
                        <textarea class="form-control" id="message" name="message" rows="4" required 
                                  placeholder="Enter your message template here..."></textarea>
                        <div class="form-text">
                            <small>Character count: <span id="char-count">0</span>/1000</small>
                        </div>
                    </div>
                    
                    <div class="file-info"></div>
                    
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle me-2"></i>Excel File Format:</h6>
                        <ul class="mb-0">
                            <li>Required column: <strong>phone</strong> (phone numbers)</li>
                            <li>Optional column: <strong>name</strong> (contact names)</li>
                            <li>Phone numbers should include country code (e.g., 628123456789)</li>
                        </ul>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-upload me-2"></i>Create Campaign
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

    </main>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/app.js"></script>
    
    <% if (locals.user) { %>
    <script>
        // Initialize socket connection
        const socket = io();
        
        // Handle WhatsApp status updates
        socket.on('whatsapp-status', (data) => {
            const statusElement = document.getElementById('whatsapp-status');
            if (data.connected) {
                statusElement.textContent = 'Connected';
                statusElement.className = 'badge bg-success';
            } else {
                statusElement.textContent = 'Disconnected';
                statusElement.className = 'badge bg-danger';
            }
        });
        
        // Character counter for message
        const messageTextarea = document.getElementById('message');
        const charCount = document.getElementById('char-count');
        
        if (messageTextarea && charCount) {
            messageTextarea.addEventListener('input', function() {
                charCount.textContent = this.value.length;
                
                if (this.value.length > 1000) {
                    charCount.style.color = 'red';
                } else {
                    charCount.style.color = 'inherit';
                }
            });
        }

        // File upload handler
        const fileInput = document.getElementById('excelFile');
        if (fileInput) {
            fileInput.addEventListener('change', function() {
                const file = this.files[0];
                const fileInfo = document.querySelector('.file-info');
                
                if (file) {
                    const fileSize = (file.size / 1024 / 1024).toFixed(2);
                    fileInfo.innerHTML = `
                        <div class="alert alert-success">
                            <i class="fas fa-file-excel me-2"></i>
                            Selected: ${file.name} (${fileSize} MB)
                        </div>
                    `;
                } else {
                    fileInfo.innerHTML = '';
                }
            });
        }

        // Start campaign buttons
        document.querySelectorAll('.start-campaign-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const campaignId = this.dataset.campaignId;
                
                if (!confirm('Are you sure you want to start this campaign? Messages will be sent to all contacts.')) {
                    return;
                }

                this.disabled = true;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

                try {
                    const response = await fetch(`/bulk/campaign/${campaignId}/start`, {
                        method: 'POST'
                    });

                    const data = await response.json();

                    if (data.success) {
                        alert('Campaign started successfully!');
                        location.reload();
                    } else {
                        alert('Failed to start campaign: ' + data.error);
                        this.disabled = false;
                        this.innerHTML = '<i class="fas fa-play"></i>';
                    }
                } catch (error) {
                    console.error('Error starting campaign:', error);
                    alert('Error starting campaign');
                    this.disabled = false;
                    this.innerHTML = '<i class="fas fa-play"></i>';
                }
            });
        });

        // Delete campaign buttons
        document.querySelectorAll('.delete-campaign-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const campaignId = this.dataset.campaignId;
                
                if (!confirm('Are you sure you want to delete this campaign? This action cannot be undone.')) {
                    return;
                }

                try {
                    const response = await fetch(`/bulk/campaign/${campaignId}`, {
                        method: 'DELETE'
                    });

                    const data = await response.json();

                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Failed to delete campaign: ' + data.error);
                    }
                } catch (error) {
                    console.error('Error deleting campaign:', error);
                    alert('Error deleting campaign');
                }
            });
        });

        // Form validation
        const campaignForm = document.getElementById('campaign-form');
        if (campaignForm) {
            campaignForm.addEventListener('submit', function(e) {
                const fileInput = document.getElementById('excelFile');
                const messageInput = document.getElementById('message');
                
                if (!fileInput.files.length) {
                    e.preventDefault();
                    alert('Please select an Excel file');
                    return;
                }
                
                if (messageInput.value.length > 1000) {
                    e.preventDefault();
                    alert('Message is too long. Maximum 1000 characters allowed.');
                    return;
                }
            });
        }
    </script>
    <% } %>
</body>
</html>